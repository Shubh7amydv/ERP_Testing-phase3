            "body": {
              "mode": "raw",
              "raw": "{\n  \"school\": \"{{school_id}}\",\n  \"student\": \"{{student_id}}\",\n  \"date\": \"2026-06-25\",\n  \"status\": \"present\",\n  \"period\": null,\n  \"remarks\": \"\",\n  \"source\": \"manual\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/attendance/",
              "host": ["{{base_url}}"],
              "path": ["attendance", ""]
