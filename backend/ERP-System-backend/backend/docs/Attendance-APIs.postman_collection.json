            "body": {
              "mode": "raw",
              "raw": "{\n  \"class_id\": {{class_id}},\n  \"section_id\": {{section_id}},\n  \"date\": \"2026-06-25\",\n  \"period_id\": null,\n  \"attendance\": [\n    {\n      \"student_id\": \"{{student_id}}\",\n      \"status\": \"present\",\n      \"remarks\": \"\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/attendance/mark/",
              "host": ["{{base_url}}"],
              "path": ["attendance", "mark", ""]
            }
          }
        },
