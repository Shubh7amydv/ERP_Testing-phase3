            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"school\": \"{{school_id}}\",\n  \"student\": \"{{student_id}}\",\n  \"date\": \"2026-06-25\",\n  \"status\": \"late\",\n  \"period\": null,\n  \"remarks\": \"Arrived late\",\n  \"source\": \"manual\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/attendance/{{attendance_id}}/",
              "host": ["{{base_url}}"],
              "path": ["attendance", "{{attendance_id}}", ""]
            }
