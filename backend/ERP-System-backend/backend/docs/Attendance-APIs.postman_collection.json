{
  "info": {
    "name": "ERP Attendance Module APIs",
    "description": "Attendance Module API Collection for ERP System\n\nPermission Requirements:\n- ModulePermission(\"attendance\") checks: attendance.view (GET), attendance.add (POST - mark), attendance.change (PUT/PATCH)\n- ModulePermission(\"reports\") checks: reports.view (GET) for report endpoints\n- IsSchoolMember ensures user belongs to a school",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000/api"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "school_id",
      "value": ""
    },
    {
      "key": "student_id",
      "value": ""
    },
    {
      "key": "period_id",
      "value": ""
    },
    {
      "key": "holiday_id",
      "value": ""
    },
    {
      "key": "leave_id",
      "value": ""
    },
    {
      "key": "class_id",
      "value": ""
    },
    {
      "key": "section_id",
      "value": ""
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login/",
              "host": ["{{base_url}}"],
              "path": ["auth", "login", ""]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if(res.access) { pm.collectionVariables.set('token', res.access); }"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Attendance Periods",
      "item": [
        {
          "name": "List Periods",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/attendance-periods/",
              "host": ["{{base_url}}"],
              "path": ["attendance-periods", ""]
            }
          }
        },
        {
          "name": "Create Period",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"school\": \"{{school_id}}\",\n  \"name\": \"Period 1\",\n  \"start_time\": \"08:00:00\",\n  \"end_time\": \"08:45:00\",\n  \"period_order\": 1,\n  \"is_active\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/attendance-periods/",
              "host": ["{{base_url}}"],
              "path": ["attendance-periods", ""]
