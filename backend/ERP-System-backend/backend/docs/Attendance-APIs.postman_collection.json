                  "var res = pm.response.json();",
                  "if(res.id) { pm.collectionVariables.set('period_id', res.id); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Period Detail",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/attendance-periods/{{period_id}}/",
              "host": ["{{base_url}}"],
              "path": ["attendance-periods", "{{period_id}}", ""]
            }
          }
        },
        {
          "name": "Update Period",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"school\": \"{{school_id}}\",\n  \"name\": \"Period 1\",\n  \"start_time\": \"08:00:00\",\n  \"end_time\": \"08:50:00\",\n  \"period_order\": 1,\n  \"is_active\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/attendance-periods/{{period_id}}/",
              "host": ["{{base_url}}"],
              "path": ["attendance-periods", "{{period_id}}", ""]
