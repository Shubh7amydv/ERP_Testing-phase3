          "name": "Mark Single Student Attendance",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"student_id\": \"{{student_id}}\",\n  \"date\": \"2026-06-25\",\n  \"status\": \"present\",\n  \"period_id\": null,\n  \"remarks\": \"\",\n  \"source\": \"manual\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/attendance/mark-single/",
              "host": ["{{base_url}}"],
              "path": ["attendance", "mark-single", ""]
            }
          }
        },
        {
          "name": "Get Class Attendance by Date",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/attendance/class/{{class_id}}/{{section_id}}/?date=2026-06-25",
              "host": ["{{base_url}}"],
              "path": ["attendance", "class", "{{class_id}}", "{{section_id}}", ""],
              "query": [
                {
                  "key": "date",
                  "value": "2026-06-25"
                }
              ]
            }
          }
        },
        {
          "name": "Get Student Attendance History",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/attendance/student/{{student_id}}/?start_date=2026-06-01&end_date=2026-06-30",
              "host": ["{{base_url}}"],
              "path": ["attendance", "student", "{{student_id}}", ""],
              "query": [
                {
                  "key": "start_date",
                  "value": "2026-06-01"
                },
                {
                  "key": "end_date",
                  "value": "2026-06-30"
                }
              ]
            }
          }
        },
        {
          "name": "Get Student Attendance Summary",
          "request": {
            "method": "GET",
