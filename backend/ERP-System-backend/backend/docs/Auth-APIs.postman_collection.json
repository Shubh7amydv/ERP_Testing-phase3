{
  "info": {
    "name": "ERP Auth API",
    "description": "Authentication & Authorization Module - All Endpoints\n\nPermission System:\n- User has ONE Role (via role_id)\n- Role has MANY Permissions (via RolePermission table)\n- Login response includes permissions array: [\"fees.view\", \"fees.add\", ...]\n- ModulePermission class maps HTTP methods to codenames:\n  - GET/HEAD/OPTIONS -> {module}.view\n  - POST -> {module}.add\n  - PUT/PATCH -> {module}.change\n  - DELETE -> {module}.delete\n\nRole/Permission endpoints require SuperAdmin role.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000/api"
    },
    {
      "key": "access_token",
      "value": ""
    },
    {
      "key": "refresh_token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if(res.access) {",
                  "  pm.environment.set('access_token', res.access);",
                  "  pm.environment.set('refresh_token', res.refresh);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login/",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"teacher@school.com\",\n  \"password\": \"teacher123\"\n}"
            }
          }
        },
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register/",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"teacher@school.com\",\n  \"password\": \"teacher123\",\n  \"first_name\": \"Rahul\",\n  \"last_name\": \"Sharma\",\n  \"role_id\": null,\n  \"phone\": \"9876543210\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/logout/",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if(res.access) {",
                  "  pm.environment.set('access_token', res.access);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/refresh/",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"
            }
          }
        },
        {
          "name": "Get Profile (Me)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auth/me/",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ]
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/auth/me/",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"Admin\",\n  \"last_name\": \"User\",\n  \"phone\": \"9999999999\"\n}"
            }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/auth/change-password/",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"old_password\": \"admin123\",\n  \"new_password\": \"newadmin123\"\n}"
            }
          }
        },
        {
          "name": "Password Reset Request",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/password-reset/",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@school.com\"\n}"
            }
          }
        },
        {
          "name": "Password Reset Confirm",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/password-reset/confirm/",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"PUT_TOKEN_HERE\",\n  \"new_password\": \"newpassword123\"\n}"
            }
          }
        },
        {
          "name": "List Sessions",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auth/sessions/",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ]
          }
        },
        {
          "name": "Delete Session",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/auth/sessions/1/",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Roles",
      "description": "Role management endpoints - Requires SuperAdmin role",
      "item": [
        {
          "name": "List Roles",
          "description": "Requires: SuperAdmin",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/roles/",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ]
          }
        },
        {
          "name": "Create Role",
          "description": "Requires: SuperAdmin",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/roles/create/",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Audit Manager\",\n  \"description\": \"Manages audits\"\n}"
            }
          }
        },
        {
          "name": "Get Role Detail",
          "description": "Requires: SuperAdmin",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/roles/1/",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ]
          }
        },
        {
          "name": "Update Role",
          "description": "Requires: SuperAdmin",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/roles/1/update/",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Super Admin Updated\",\n  \"description\": \"Updated description\"\n}"
            }
          }
        },
        {
          "name": "Delete Role",
          "description": "Requires: SuperAdmin",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/roles/11/delete/",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ]
          }
        },
        {
          "name": "Assign Permissions to Role",
          "description": "Requires: SuperAdmin. Response includes 'assigned' (newly added) and 'already_existed' arrays.",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/roles/1/assign-permissions/",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"permission_ids\": [1, 2, 3, 4]\n}"
            }
          }
        },
        {
          "name": "Remove Permissions from Role",
          "description": "Requires: SuperAdmin",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/roles/1/remove-permissions/",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"permission_ids\": [1, 2]\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Permissions",
      "description": "Permission management endpoints - Requires SuperAdmin. 30 predefined codenames available.",
      "item": [
        {
          "name": "List Permissions",
          "description": "Requires: SuperAdmin. Returns all available permission codenames (fees.view, fees.add, attendance.mark, etc.)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/permissions/",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Permission Codenames Reference",
      "description": "Available permission codenames for ModulePermission:\n\n- admissions.view, admissions.add, admissions.change, admissions.delete\n- fees.view, fees.add, fees.change, fees.delete, fees.collect\n- attendance.view, attendance.mark, attendance.change\n- exams.view, exams.add, exams.change, exams.delete\n- library.view, library.add, library.issue, library.return\n- hr.view, hr.add, hr.change, hr.delete, hr.payroll\n- transport.view, transport.add, transport.change, transport.delete\n- reports.view, reports.export\n- settings.view, settings.change",
      "item": []
    }
  ]
}
