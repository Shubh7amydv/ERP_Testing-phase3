            "body": { "mode": "raw", "raw": "{\n  \"school\": 1,\n  \"name\": \"Mathematics\",\n  \"code\": \"MATH\",\n  \"type\": \"theory\",\n  \"max_marks\": 100,\n  \"passing_marks\": 33,\n  \"is_active\": true\n}", "options": { "raw": { "language": "json" } } }
