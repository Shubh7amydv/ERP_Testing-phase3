          "name": "Update Subject",
          "request": {
            "method": "PATCH",
            "url": { "raw": "{{base_url}}/subjects/1/", "host": ["{{base_url}}"], "path": ["subjects", "1"] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Mathematics Updated\"\n}", "options": { "raw": { "language": "json" } } }
