            "url": { "raw": "{{base_url}}/exam-schedules/bulk-create/", "host": ["{{base_url}}"], "path": ["exam-schedules", "bulk-create"] },
            "body": { "mode": "raw", "raw": "{\n  \"exam_id\": 1,\n  \"class_id\": 1,\n  \"schedules\": [\n    {\n      \"subject_id\": 1,\n      \"date\": \"2026-07-15\",\n      \"start_time\": \"09:00:00\",\n      \"end_time\": \"12:00:00\",\n      \"max_marks\": 100,\n      \"passing_marks\": 33,\n      \"room_no\": \"101\",\n      \"instructions\": \"\"\n    },\n    {\n      \"subject_id\": 2,\n      \"date\": \"2026-07-16\",\n      \"start_time\": \"09:00:00\",\n      \"end_time\": \"12:00:00\",\n      \"max_marks\": 100,\n      \"passing_marks\": 33,\n      \"room_no\": \"102\",\n      \"instructions\": \"\"\n    }\n  ]\n}", "options": { "raw": { "language": "json" } } }
