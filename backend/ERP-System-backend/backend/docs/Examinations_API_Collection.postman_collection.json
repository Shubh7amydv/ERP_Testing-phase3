{
  "info": {
    "name": "ERP System - Examinations APIs",
    "description": "Complete API collection for Examinations module",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000/api" },
    { "key": "token", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Exam Types",
      "item": [
        {
          "name": "List Exam Types",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/exam-types/?page=1&limit=10", "host": ["{{base_url}}"], "path": ["exam-types"], "query": [{ "key": "page", "value": "1" }, { "key": "limit", "value": "10" }] }
          }
        },
        {
          "name": "Create Exam Type",
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/exam-types/", "host": ["{{base_url}}"], "path": ["exam-types"] },
            "body": { "mode": "raw", "raw": "{\n  \"school\": 1,\n  \"name\": \"Mid Term\",\n  \"description\": \"Mid term examination\",\n  \"weightage\": 50,\n  \"is_active\": true\n}", "options": { "raw": { "language": "json" } } }
          }
        },
        {
          "name": "Get Exam Type",
          "request": { "method": "GET", "url": { "raw": "{{base_url}}/exam-types/1/", "host": ["{{base_url}}"], "path": ["exam-types", "1"] } }
        },
        {
          "name": "Update Exam Type",
          "request": {
            "method": "PATCH",
            "url": { "raw": "{{base_url}}/exam-types/1/", "host": ["{{base_url}}"], "path": ["exam-types", "1"] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Mid Term Updated\"\n}", "options": { "raw": { "language": "json" } } }
          }
        },
        {
          "name": "Delete Exam Type",
          "request": { "method": "DELETE", "url": { "raw": "{{base_url}}/exam-types/1/", "host": ["{{base_url}}"], "path": ["exam-types", "1"] } }
        }
      ]
    },
