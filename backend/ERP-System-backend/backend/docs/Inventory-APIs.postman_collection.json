{
  "info": {
    "name": "ERP System - Inventory Module APIs",
    "description": "Complete Postman collection for all Inventory module APIs including Categories, Items, Stock Entries, Suppliers, Purchase Orders, and Reports.\n\nBase URL: http://localhost:8000\nAuthentication: JWT Bearer Token\n\nPermission Requirements:\n- IsSchoolMember: user must be authenticated and belong to a school\n\nSteps:\n1. Login via POST /api/auth/login/ to get access token\n2. Ensure user has a role with inventory permissions assigned\n3. Set the token in collection variables or Authorization header\n4. Use the token for all subsequent requests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000"
    },
    {
      "key": "access_token",
      "value": ""
    },
    {
      "key": "category_id",
      "value": "1"
    },
    {
      "key": "item_id",
      "value": "1"
    },
    {
      "key": "stock_entry_id",
      "value": "1"
    },
    {
      "key": "supplier_id",
      "value": "1"
    },
    {
      "key": "purchase_order_id",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Inventory Categories",
      "description": "CRUD operations for inventory categories. Categories group items by type (e.g., Electronics, Furniture, Stationery).",
      "item": [
        {
          "name": "List Categories",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/categories/",
              "host": ["{{base_url}}"],
              "path": ["api", "categories", ""]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ]
          }
        },
        {
          "name": "Create Category",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if(res.id) {",
                  "  pm.environment.set('category_id', res.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/categories/",
              "host": ["{{base_url}}"],
              "path": ["api", "categories", ""]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Electronics\",\n  \"description\": \"Electronic items and gadgets\",\n  \"is_active\": true\n}"
            }
          }
        },
        {
          "name": "Get Category",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/categories/{{category_id}}/",
              "host": ["{{base_url}}"],
              "path": ["api", "categories", "{{category_id}}", ""]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ]
          }
        },
        {
          "name": "Update Category",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{base_url}}/api/categories/{{category_id}}/",
              "host": ["{{base_url}}"],
              "path": ["api", "categories", "{{category_id}}", ""]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Electronics Updated\",\n  \"description\": \"Electronic items and gadgets - updated\",\n  \"is_active\": true\n}"
            }
          }
        },
        {
          "name": "Partial Update Category",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{base_url}}/api/categories/{{category_id}}/",
              "host": ["{{base_url}}"],
              "path": ["api", "categories", "{{category_id}}", ""]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Electronics - Renamed\"\n}"
            }
          }
        },
        {
          "name": "Delete Category",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/api/categories/{{category_id}}/",
              "host": ["{{base_url}}"],
              "path": ["api", "categories", "{{category_id}}", ""]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ]
          }
        }
      ]
    },
