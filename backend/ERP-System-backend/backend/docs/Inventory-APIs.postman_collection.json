              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"item_id\": {{item_id}},\n  \"entry_type\": \"purchase\",\n  \"quantity\": \"50.00\",\n  \"unit_price\": \"15000.00\",\n  \"supplier\": \"Dell Technologies\",\n  \"invoice_no\": \"INV-2026-001\",\n  \"remarks\": \"Bulk purchase of monitors\",\n  \"entry_date\": \"2026-07-14\"\n}"
