              "raw": "{\n  \"school\": {{school_id}},\n  \"title\": \"Python Crash Course\",\n  \"author\": \"Eric Matthes\",\n  \"isbn\": \"9781593279288\",\n  \"publisher\": \"No Starch Press\",\n  \"category\": {{category_id}},\n  \"edition\": \"3rd\",\n  \"year_published\": 2023,\n  \"language\": \"English\",\n  \"pages\": 544,\n  \"description\": \"A Hands-On, Project-Based Introduction to Programming - Updated\",\n  \"total_copies\": 5,\n  \"available_copies\": 4,\n  \"location\": \"Shelf A-1\",\n  \"price\": 39.99,\n  \"is_active\": true\n}"
