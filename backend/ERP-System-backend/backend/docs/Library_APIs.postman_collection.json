{
  "info": {
    "name": "ERP Library Module APIs",
    "description": "Library Module API Collection for ERP System\n\nPermission Requirements:\n- IsSchoolMember ensures user belongs to a school\n\nEndpoints:\n- Book Categories: CRUD operations for book categories\n- Books: CRUD + search, available, overdue\n- Book Issues: Issue/Return books, active/overdue lists, by-member\n- Book Reservations: Reserve, fulfill, cancel\n- Library Members: CRUD + issue history\n- Reports: Popular books, member activity, overdue summary, inventory",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000/api"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "school_id",
      "value": ""
    },
    {
      "key": "category_id",
      "value": ""
    },
    {
      "key": "book_id",
      "value": ""
    },
    {
      "key": "issue_id",
      "value": ""
    },
    {
      "key": "reservation_id",
      "value": ""
    },
    {
      "key": "member_id",
      "value": ""
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login/",
              "host": ["{{base_url}}"],
              "path": ["auth", "login", ""]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if(res.access) { pm.collectionVariables.set('token', res.access); }"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Book Categories",
      "item": [
        {
          "name": "List Categories",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/book-categories/",
              "host": ["{{base_url}}"],
              "path": ["book-categories", ""]
            }
          }
        },
        {
          "name": "Create Category",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"school\": {{school_id}},\n  \"name\": \"Fiction\",\n  \"description\": \"Fiction books\",\n  \"is_active\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/book-categories/",
              "host": ["{{base_url}}"],
              "path": ["book-categories", ""]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if(res.id) { pm.collectionVariables.set('category_id', res.id); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Category Detail",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/book-categories/{{category_id}}/",
              "host": ["{{base_url}}"],
              "path": ["book-categories", "{{category_id}}", ""]
            }
          }
        },
        {
          "name": "Update Category",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"school\": {{school_id}},\n  \"name\": \"Fiction\",\n  \"description\": \"Fiction books - Updated\",\n  \"is_active\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/book-categories/{{category_id}}/",
              "host": ["{{base_url}}"],
              "path": ["book-categories", "{{category_id}}", ""]
            }
          }
        },
        {
          "name": "Delete Category",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/book-categories/{{category_id}}/",
              "host": ["{{base_url}}"],
              "path": ["book-categories", "{{category_id}}", ""]
            }
          }
        }
      ]
    },
