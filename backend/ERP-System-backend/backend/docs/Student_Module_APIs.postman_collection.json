{
  "info": {
    "name": "ERP System - Student Module APIs",
    "description": "Complete Postman collection for all Student Module APIs including Admissions, Academic Classes, Sections, Castes, Houses, Categories, and Sibling Groups.\n\nBase URL: http://localhost:8000\n\nAuthentication: All endpoints require JWT token in Authorization header.\nFormat: Bearer <access_token>\n\nPermission Requirements:\n- ModulePermission(\"admissions\") checks: admissions.view (GET), admissions.add (POST), admissions.change (PUT/PATCH), admissions.delete (DELETE)\n- IsSchoolMember ensures user belongs to a school",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "admission_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "class_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "section_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "caste_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "house_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "category_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "sibling_group_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (Get Access Token)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login/",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login", ""]
            },
            "description": "Login and get JWT access token. Save the access_token from response to collection variable."
          },
          "response": []
        }
      ],
      "description": "Authentication endpoints"
    },
    {
      "name": "Admissions",
      "item": [
        {
          "name": "List Admissions",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/admissions/?page=1&limit=10",
              "host": ["{{base_url}}"],
              "path": ["api", "admissions", ""],
              "query": [
                { "key": "page", "value": "1", "description": "Page number" },
                { "key": "limit", "value": "10", "description": "Records per page" },
                { "key": "year", "value": "", "description": "Academic year (e.g. 2026-2027)", "disabled": true },
                { "key": "search", "value": "", "description": "Search by name, admission_no, father_name, phone", "disabled": true },
                { "key": "admission_class", "value": "", "description": "Filter by class", "disabled": true },
                { "key": "section", "value": "", "description": "Filter by section", "disabled": true },
                { "key": "gender", "value": "", "description": "Male or Female", "disabled": true },
                { "key": "house", "value": "", "description": "Filter by house", "disabled": true },
                { "key": "ordering", "value": "", "description": "roll_number or -created_at", "disabled": true }
              ]
            },
            "description": "Fetch paginated list of all active admissions with filtering, search, and ordering."
          },
          "response": []
        },
        {
          "name": "Create Admission",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "first_name", "value": "Rahul", "type": "text" },
                { "key": "last_name", "value": "Sharma", "type": "text" },
                { "key": "email", "value": "rahul@example.com", "type": "text", "description": "Optional - creates user account if provided" },
                { "key": "password", "value": "password123", "type": "text", "description": "Optional - password for created user" },
                { "key": "phone", "value": "9876543210", "type": "text" },
                { "key": "address", "value": "123 Main Street, Delhi", "type": "text" },
                { "key": "date_of_birth", "value": "2010-05-15", "type": "text", "description": "YYYY-MM-DD" },
                { "key": "gender", "value": "Male", "type": "text" },
                { "key": "blood_group", "value": "O+", "type": "text" },
                { "key": "category", "value": "General", "type": "text" },
                { "key": "caste", "value": "Hindu", "type": "text" },
                { "key": "religion", "value": "Hinduism", "type": "text" },
                { "key": "aadhaar_no", "value": "123456789012", "type": "text" },
                { "key": "father_name", "value": "Suresh Sharma", "type": "text" },
                { "key": "father_occupation", "value": "Business", "type": "text" },
                { "key": "mother_name", "value": "Sunita Sharma", "type": "text" },
                { "key": "admission_class", "value": "I", "type": "text", "description": "e.g. I, II, LKG, UKG" },
                { "key": "section", "value": "A", "type": "text" },
                { "key": "roll_number", "value": "1", "type": "text" },
                { "key": "house", "value": "Red", "type": "text" },
                { "key": "bus_route", "value": "Route-1", "type": "text" },
                { "key": "medium", "value": "English", "type": "text" },
                { "key": "date_of_admission", "value": "2026-04-01", "type": "text" },
                { "key": "status", "value": "Pending", "type": "text" },
                { "key": "photo", "type": "file", "src": [] },
                { "key": "parent_photo", "type": "file", "src": [] },
                { "key": "tc_document", "type": "file", "src": [] },
                { "key": "aadhaar_document", "type": "file", "src": [] }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/admissions/",
              "host": ["{{base_url}}"],
              "path": ["api", "admissions", ""]
            },
            "description": "Create a new student admission. Auto-generates admission_no. Supports multipart/form-data for file uploads."
          },
          "response": []
        },
        {
          "name": "Retrieve Admission",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/admissions/{{admission_id}}/",
              "host": ["{{base_url}}"],
              "path": ["api", "admissions", "{{admission_id}}", ""]
            },
            "description": "Fetch details of a single admission by UUID."
          },
          "response": []
        },
        {
          "name": "Update Admission (PUT)",
          "request": {
            "method": "PUT",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "first_name", "value": "Rahul", "type": "text" },
                { "key": "last_name", "value": "Sharma", "type": "text" },
                { "key": "phone", "value": "9876543210", "type": "text" },
                { "key": "admission_class", "value": "I", "type": "text" },
                { "key": "section", "value": "A", "type": "text" },
                { "key": "roll_number", "value": "1", "type": "text" }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/admissions/{{admission_id}}/",
              "host": ["{{base_url}}"],
              "path": ["api", "admissions", "{{admission_id}}", ""]
            },
            "description": "Full update of an admission record. All fields expected (full replacement)."
          },
          "response": []
        },
        {
          "name": "Partial Update Admission (PATCH)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"section\": \"B\",\n  \"roll_number\": 5\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/admissions/{{admission_id}}/",
              "host": ["{{base_url}}"],
              "path": ["api", "admissions", "{{admission_id}}", ""]
            },
            "description": "Partial update - only provided fields are updated."
          },
          "response": []
        },
        {
          "name": "Delete Admission (Soft Delete)",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/admissions/{{admission_id}}/",
              "host": ["{{base_url}}"],
              "path": ["api", "admissions", "{{admission_id}}", ""]
            },
            "description": "Soft delete - sets is_active = false. Does NOT permanently remove the record."
          },
          "response": []
        },
        {
          "name": "Filter Admissions by Groups",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/admissions/filter-by-groups/?year=2026-2027&page=1&limit=10",
              "host": ["{{base_url}}"],
              "path": ["api", "admissions", "filter-by-groups", ""],
              "query": [
                { "key": "year", "value": "2026-2027", "description": "Academic year" },
                { "key": "groups", "value": "[{\"class\":\"I\",\"section\":\"A\"},{\"class\":\"II\"}]", "description": "JSON array of class/section filters", "disabled": true },
                { "key": "ordering", "value": "", "description": "house, new, or default", "disabled": true },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            },
            "description": "Filter admissions by class/section groups with ordering and pagination."
          },
          "response": []
        },
        {
          "name": "Class-wise Total Students Statistics",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/admissions/class-wise-total-students/?year=2026-2027",
              "host": ["{{base_url}}"],
              "path": ["api", "admissions", "class-wise-total-students", ""],
              "query": [
                { "key": "year", "value": "2026-2027", "description": "Academic year (default: current year)" }
              ]
            },
            "description": "Returns aggregated student statistics (boys, girls, total, dropout, TC, new students) grouped by class and section."
          },
          "response": []
        },
        {
          "name": "Bulk Update Admissions",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "[\n  {\n    \"id\": \"admission-uuid-1\",\n    \"first_name\": \"Updated Name\",\n    \"section\": \"B\"\n  },\n  {\n    \"id\": \"admission-uuid-2\",\n    \"roll_number\": 5\n  }\n]"
            },
            "url": {
              "raw": "{{base_url}}/api/admissions/bulk-update/",
              "host": ["{{base_url}}"],
              "path": ["api", "admissions", "bulk-update", ""]
            },
            "description": "Bulk update multiple admission records in one request. Each object must have 'id' plus fields to update."
          },
          "response": []
        }
      ],
      "description": "Student Admission CRUD and management endpoints"
    },
